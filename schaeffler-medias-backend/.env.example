# Copy to .env and fill in to enable conversational replies via Claude (RealLLMClient).
# Without a key, the backend runs with MockLLMClient (canned replies) — the app still works.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Comma-separated CORS origins for the frontend (default already allows 5173/3000)
# CORS_ORIGINS=http://localhost:5173
